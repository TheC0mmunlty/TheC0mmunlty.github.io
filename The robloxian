<!DOCTYPE html>
<html>
<head>
  <title>Roblox Forum</title>
  <style>
    body {
      background: #d9d9d9;
      font-family: Arial;
    }

    .container {
      width: 700px;
      margin: 40px auto;
      background: #f2f2f2;
      border: 1px solid #999;
    }

    .header {
      background: #cfcfcf;
      padding: 10px;
      font-weight: bold;
      border-bottom: 1px solid #999;
    }

    .new-post {
      padding: 10px;
      border-bottom: 1px solid #999;
    }

    input, textarea {
      width: 100%;
      margin-top: 5px;
      padding: 5px;
      border: 1px solid #aaa;
    }

    button {
      margin-top: 5px;
      padding: 5px;
      background: #3b6ea5;
      color: white;
      border: none;
      cursor: pointer;
    }

    .post {
      display: flex;
      border-top: 1px solid #ccc;
      background: white;
      padding: 10px;
    }

    .profile {
      width: 150px;
      border-right: 1px solid #ddd;
      padding-right: 10px;
      margin-right: 10px;
      text-align: center;
    }

    .avatar {
      width: 60px;
      height: 60px;
      background: #bbb;
      margin: auto;
      border-radius: 5px;
    }

    .username {
      font-weight: bold;
      color: #2b4f8a;
      margin-top: 5px;
    }

    .joined {
      font-size: 11px;
      color: #666;
    }

    .badges {
      margin-top: 5px;
    }

    .badge {
      display: inline-block;
      font-size: 10px;
      background: #3b6ea5;
      color: white;
      padding: 2px 4px;
      margin: 2px;
      border-radius: 3px;
    }

    .content {
      flex: 1;
    }

    .message {
      margin-top: 5px;
    }

    .reply-btn {
      margin-top: 5px;
      font-size: 12px;
      background: #888;
    }

    .replies {
      margin-left: 20px;
      margin-top: 10px;
      border-left: 2px solid #ccc;
      padding-left: 10px;
    }

    .reply-box {
      margin-top: 5px;
      display: none;
    }
  </style>
</head>

<body>

<div class="container">

  <div class="header">💬 Roblox-Style Forum (2014 Profile Update)</div>

  <div class="new-post">
    <input id="user" placeholder="Username">
    <textarea id="msg" placeholder="Write your post..."></textarea>
    <button onclick="addPost()">Post</button>
  </div>

  <div id="posts"></div>

</div>

<script>
function getRandomBadges() {
  const allBadges = ["Builder", "Veteran", "Beta Tester", "Active"];
  let count = Math.floor(Math.random() * 3) + 1;
  let shuffled = allBadges.sort(() => 0.5 - Math.random());
  return shuffled.slice(0, count);
}

function addPost() {
  let user = document.getElementById("user").value;
  let msg = document.getElementById("msg").value;

  let joinYear = 2010 + Math.floor(Math.random() * 10);
  let joinDate = "Joined " + joinYear;

  let badges = getRandomBadges();

  let badgeHTML = badges.map(b => `<div class="badge">${b}</div>`).join("");

  let post = document.createElement("div");
  post.className = "post";

  post.innerHTML = `
    <div class="profile">
      <div class="avatar"></div>
      <div class="username">${user}</div>
      <div class="joined">${joinDate}</div>
      <div class="badges">${badgeHTML}</div>
    </div>

    <div class="content">
      <div class="message">${msg}</div>

      <button class="reply-btn" onclick="showReply(this)">Reply</button>

      <div class="reply-box">
        <input placeholder="Reply username">
        <input placeholder="Reply message">
        <button onclick="addReply(this)">Send</button>
      </div>

      <div class="replies"></div>
    </div>
  `;

  document.getElementById("posts").prepend(post);
}

function showReply(btn) {
  let box = btn.parentElement.querySelector(".reply-box");
  box.style.display = box.style.display === "none" ? "block" : "none";
}

function addReply(btn) {
  let box = btn.parentElement;
  let post = box.parentElement;

  let inputs = box.querySelectorAll("input");
  let user = inputs[0].value;
  let msg = inputs[1].value;

  let reply = document.createElement("div");
  reply.innerHTML = `
    <div class="username">${user}</div>
    <div class="message">${msg}</div>
  `;

  post.querySelector(".replies").appendChild(reply);

  inputs[0].value = "";
  inputs[1].value = "";
  box.style.display = "none";
}
</script>

</body>
</html>
