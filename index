<!DOCTYPE html>
<html>
<head>
  <title>Roblox Forum 2014</title>
  <style>
    body {
      margin: 0;
      background: #cfcfcf;
      font-family: Arial;
    }

    /* TOP BAR */
    .topbar {
      background: #3b6ea5;
      color: white;
      padding: 10px;
      font-weight: bold;
    }

    .container {
      width: 750px;
      margin: 20px auto;
    }

    /* POST BOX */
    .new-post {
      background: #e9e9e9;
      padding: 10px;
      border: 1px solid #999;
      margin-bottom: 10px;
    }

    input, textarea {
      width: 100%;
      margin-top: 5px;
      padding: 6px;
      border: 1px solid #aaa;
    }

    button {
      margin-top: 5px;
      padding: 6px;
      background: #3b6ea5;
      color: white;
      border: none;
      cursor: pointer;
    }

    /* POST */
    .post {
      display: flex;
      background: white;
      border: 1px solid #999;
      margin-bottom: 10px;
    }

    .profile {
      width: 160px;
      background: #f3f3f3;
      border-right: 1px solid #ccc;
      text-align: center;
      padding: 10px;
    }

    .avatar {
      width: 60px;
      height: 60px;
      background: #bbb;
      margin: auto;
      border-radius: 4px;
    }

    .username {
      font-weight: bold;
      color: #2b4f8a;
      margin-top: 5px;
    }

    .joined {
      font-size: 11px;
      color: #666;
    }

    .badge {
      display: inline-block;
      font-size: 10px;
      background: #3b6ea5;
      color: white;
      padding: 2px 4px;
      margin: 2px;
      border-radius: 3px;
    }

    .content {
      flex: 1;
      padding: 10px;
    }

    .message {
      margin-bottom: 10px;
    }

    .reply-btn {
      background: #888;
      font-size: 12px;
    }

    .replies {
      margin-left: 15px;
      border-left: 2px solid #ccc;
      padding-left: 10px;
      margin-top: 10px;
    }

    .reply-box {
      display: none;
      margin-top: 5px;
    }
  </style>
</head>

<body>

<div class="topbar">
  Roblox Community Forum (2014 Style)
</div>

<div class="container">

  <!-- NEW POST -->
  <div class="new-post">
    <input id="user" placeholder="Username">
    <textarea id="msg" placeholder="Write something..."></textarea>
    <button onclick="addPost()">Post</button>
  </div>

  <div id="posts"></div>

</div>

<script>
function getBadges() {
  const badges = ["Member", "Veteran", "Builder", "Active"];
  return badges.sort(() => 0.5 - Math.random()).slice(0, 2);
}

function addPost() {
  let user = document.getElementById("user").value;
  let msg = document.getElementById("msg").value;

  let join = 2009 + Math.floor(Math.random() * 10);
  let badgeList = getBadges();

  let badgeHTML = badgeList.map(b => `<div class="badge">${b}</div>`).join("");

  let post = document.createElement("div");
  post.className = "post";

  post.innerHTML = `
    <div class="profile">
      <div class="avatar"></div>
      <div class="username">${user}</div>
      <div class="joined">Joined ${join}</div>
      <div>${badgeHTML}</div>
    </div>

    <div class="content">
      <div class="message">${msg}</div>

      <button class="reply-btn" onclick="toggleReply(this)">Reply</button>

      <div class="reply-box">
        <input placeholder="Username">
        <input placeholder="Reply...">
        <button onclick="addReply(this)">Send</button>
      </div>

      <div class="replies"></div>
    </div>
  `;

  document.getElementById("posts").prepend(post);
}

function toggleReply(btn) {
  let box = btn.parentElement.querySelector(".reply-box");
  box.style.display = box.style.display === "none" ? "block" : "none";
}

function addReply(btn) {
  let box = btn.parentElement;
  let inputs = box.querySelectorAll("input");

  let user = inputs[0].value;
  let msg = inputs[1].value;

  let reply = document.createElement("div");
  reply.innerHTML = `<b>${user}</b>: ${msg}`;

  box.parentElement.querySelector(".replies").appendChild(reply);

  inputs[0].value = "";
  inputs[1].value = "";
  box.style.display = "none";
}
</script>

</body>
</html>
